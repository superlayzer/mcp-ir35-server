{
  "name": "mcp-ir35-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/node.ts",
    "start": "tsx src/node.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@hono/node-server": "2.0.1",
    "fetch-to-node": "2.1.0",
    "hono": "4.12.18",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260131.0",
    "@types/node": "20.19.30",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "wrangler": "4.80.0"
  },
  "description": "MCP server for UK IR35 contract analysis: case-law lookup, contract risk dashboard, CEST-style assessment, and Status Determination Statement builder",
  "author": "Superlayzer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/superlayzer/mcp-ir35-server.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ir35",
    "off-payroll",
    "uk-tax",
    "contract-analysis",
    "contractor",
    "cloudflare-workers",
    "ext-apps"
  ],
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
