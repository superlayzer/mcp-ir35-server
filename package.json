{
  "name": "mcp-ir35-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/node.ts",
    "start": "tsx src/node.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@hono/node-server": "^1.19.13",
    "fetch-to-node": "^2.1.0",
    "hono": "^4.12.12",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "description": "MCP server for UK IR35 contract analysis: case-law lookup, contract risk dashboard, CEST-style assessment, and Status Determination Statement builder",
  "author": "Superlayzer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/superlayzer/mcp-ir35-server.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ir35",
    "off-payroll",
    "uk-tax",
    "contract-analysis",
    "contractor",
    "cloudflare-workers",
    "ext-apps"
  ],
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
